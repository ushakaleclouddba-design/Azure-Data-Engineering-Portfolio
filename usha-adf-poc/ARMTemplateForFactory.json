							},
							"name": "SinkGold"
						}
					],
					"transformations": [
						{
							"name": "aggregate1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          TransactionID as string,",
						"          AccountID as string,",
						"          TransactionDate as string,",
						"          PostedDate as string,",
						"          TransactionType as string,",
						"          Amount as string,",
						"          RunningBalance as string,",
						"          Description as string,",
						"          ReferenceNumber as string,",
						"          Channel as string,",
						"          Remarks as string,",
