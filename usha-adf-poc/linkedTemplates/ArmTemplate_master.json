{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "usha-adf-poc"
		},
		"LS_ADLS_Gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_Gen2'"
		},
		"LS_Blob_Staging_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Blob_Staging'"
		},
		"LS_SQLServer_Node5_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQLServer_Node5'"
		},
		"LS_FileSystem_Node5_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_FileSystem_Node5'"
		},
		"LS_ADLS_Gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://ushaadfpocadls.dfs.core.windows.net/"
		},
		"LS_SQLServer_Node5_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "Node5"
		},
		"LS_SQLServer_Node5_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "CoreBank_onPrem_Poc"
		},
		"LS_SQLServer_Node5_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "ushadc0\\ushakale"
		},
		"AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogServerEndpoint": {
			"type": "string",
			"defaultValue": "usha-poc-sqlsvr.database.windows.net"
		},
		"AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogAdminUserName": {
			"type": "string",
			"defaultValue": "ssisadmin"
		},
		"AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogAdminPassword": {
			"type": "secureString"
		},
		"LS_FileSystem_Node5_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "c:\\ssis_output"
		},
		"LS_FileSystem_Node5_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "ushadc0\\ushakale"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "usha-adf-poc_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_Gen2_accountKey": {
						"value": "[parameters('LS_ADLS_Gen2_accountKey')]"
					},
					"LS_Blob_Staging_connectionString": {
						"value": "[parameters('LS_Blob_Staging_connectionString')]"
					},
					"LS_SQLServer_Node5_password": {
						"value": "[parameters('LS_SQLServer_Node5_password')]"
					},
					"LS_FileSystem_Node5_password": {
						"value": "[parameters('LS_FileSystem_Node5_password')]"
					},
					"LS_ADLS_Gen2_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Gen2_properties_typeProperties_url')]"
					},
					"LS_SQLServer_Node5_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLServer_Node5_properties_typeProperties_server')]"
					},
					"LS_SQLServer_Node5_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLServer_Node5_properties_typeProperties_database')]"
					},
					"LS_SQLServer_Node5_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLServer_Node5_properties_typeProperties_userName')]"
					},
					"AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogServerEndpoint": {
						"value": "[parameters('AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogServerEndpoint')]"
					},
					"AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogAdminUserName": {
						"value": "[parameters('AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogAdminUserName')]"
					},
					"AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogAdminPassword": {
						"value": "[parameters('AzureSSIS-IR_properties_typeProperties_ssisProperties_catalogInfo_catalogAdminPassword')]"
					},
					"LS_FileSystem_Node5_properties_typeProperties_host": {
						"value": "[parameters('LS_FileSystem_Node5_properties_typeProperties_host')]"
					},
					"LS_FileSystem_Node5_properties_typeProperties_userId": {
						"value": "[parameters('LS_FileSystem_Node5_properties_typeProperties_userId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}