							{
								"activity": "Lookup_IntrestRates",
								"dependencyConditions": [
									"Completed"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "DelimitedTextSource",
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"recursive": true,
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "DelimitedTextReadSettings"
								}
							},
							"sink": {
								"type": "AzureSqlSink",
								"preCopyScript": {
									"value": "DELETE FROM dbo.LoanApplications WHERE BranchID = '@{pipeline().parameters.BranchID}' AND RunDate = '@{pipeline().parameters.RunDate}'",
									"type": "Expression"
								},
								"writeBehavior": "insert",
								"sqlWriterUseTableLock": false,
								"disableMetricsCollection": false
							},
							"enableStaging": false,
							"translator": {
								"type": "TabularTranslator",
								"typeConversion": true,
								"typeConversionSettings": {
									"allowDataTruncation": true,
									"treatBooleanAsNumber": false
								}
							}
						},
						"inputs": [
							{
								"referenceName": "DS_ADLS_Landing",
								"type": "DatasetReference",
								"parameters": {
									"BranchID": "@pipeline().parameters.BranchID"
								}
							}
						],
						"outputs": [
							{
								"referenceName": "DS_AzureSQL_LoanApplications",
								"type": "DatasetReference",
								"parameters": {}
							}
						]
					},
					{
						"name": "StoredProc_AuditLog",
						"type": "SqlServerStoredProcedure",
						"dependsOn": [
							{
								"activity": "CopyData_ToSQL",
								"dependencyConditions": [
									"Completed"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"storedProcedureName": "[[dbo].[usp_LogPipelineRun]",
							"storedProcedureParameters": {
								"ApprovedCount": {
									"value": {
										"value": "@activity('CopyData_ToSQL').output.rowsCopied",
										"type": "Expression"
									},
									"type": "Int32"
								},
								"BranchID": {
									"value": {
										"value": "@pipeline().parameters.BranchID",
										"type": "Expression"
									},
									"type": "String"
								},
								"PipelineRunID": {
									"value": {
										"value": "@pipeline().RunId",
										"type": "Expression"
									},
									"type": "String"
								},
								"RejectedCount": {
									"value": "0",
									"type": "Int32"
								},
								"RunDate": {
									"value": {
										"value": "@pipeline().parameters.RunDate",
										"type": "Expression"
									},
									"type": "DateTime"
								},
								"Status": {
									"value": "SUCCESS",
									"type": "String"
								}
							}
						},
						"linkedServiceName": {
							"referenceName": "LS_AzureSQL_LoanProcessing",
							"type": "LinkedServiceReference"
						}
					},
					{
						"name": "Script_UpdateStatus",
						"type": "Script",
						"dependsOn": [
							{
								"activity": "StoredProc_AuditLog",
								"dependencyConditions": [
									"Completed"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"linkedServiceName": {
							"referenceName": "LS_AzureSQL_LoanProcessing",
							"type": "LinkedServiceReference"
						},
						"typeProperties": {
							"scripts": [
								{
									"type": "NonQuery",
									"text": {
										"value": "UPDATE dbo.LoanApplications \nSET ProcessingStatus = 'PROCESSED', UpdatedAt = GETDATE() \nWHERE BranchID = '@{pipeline().parameters.BranchID}' \nAND RunDate = '@{pipeline().parameters.RunDate}'",
										"type": "Expression"
									}
								}
							],
							"scriptBlockExecutionTimeout": "02:00:00"
						}
					},
					{
						"name": "Delete_LandingFile",
						"type": "Delete",
						"dependsOn": [
							{
								"activity": "Script_UpdateStatus",
								"dependencyConditions": [
									"Completed"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"dataset": {
								"referenceName": "DS_ADLS_Landing",
								"type": "DatasetReference",
								"parameters": {
									"BranchID": "@pipeline().parameters.BranchID"
								}
							},
							"logStorageSettings": {
								"linkedServiceName": {
									"referenceName": "LS_ADLS_Gen2",
									"type": "LinkedServiceReference"
								},
								"path": "curated/delete-logs"
							},
							"enableLogging": true,
							"storeSettings": {
								"type": "AzureBlobFSReadSettings",
								"recursive": false,
								"enablePartitionDiscovery": false
							}
						}
					},
					{
						"name": "Fail_SLABreach",
						"type": "Fail",
						"dependsOn": [
							{
								"activity": "CopyData_ToSQL",
								"dependencyConditions": [
									"Failed"
								]
							},
							{
								"activity": "StoredProc_AuditLog",
								"dependencyConditions": [
									"Failed"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"message": {
								"value": "@concat('Loan processing failed for branch ',pipeline().parameters.BranchID,' on ',pipeline().parameters.RunDate)",
								"type": "Expression"
							},
							"errorCode": "LOAN_FAIL_001"
						}
					},
					{
						"name": "SetVar_FileArrived_True",
						"type": "SetVariable",
						"dependsOn": [
							{
								"activity": "SetVar_RetryCount",
								"dependencyConditions": [
									"Completed"
								]
							}
						],
						"policy": {
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"variableName": "FileArrived",
							"value": "true"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"parameters": {
					"BranchID": {
						"type": "string"
					},
					"RunDate": {
						"type": "string"
					},
					"LoanType": {
						"type": "string"
					}
				},
				"variables": {
					"RetryCount": {
						"type": "Integer"
					},
					"FileArrived": {
						"type": "String"
					},
					"RejectedIDs": {
						"type": "Array"
					}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/DS_Node5_SQL_Loans')]",
				"[concat(variables('factoryId'), '/datasets/DS_AzureSQL_RateTable')]",
				"[concat(variables('factoryId'), '/datasets/DS_AzureSQL_LoanApplications')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/TriggerDailySilverToGold')]",
			"type": "Microsoft.DataFactory/factories/triggers",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"runtimeState": "Stopped",
				"pipelines": [
					{
						"pipelineReference": {
							"referenceName": "PL_CoreBank_SSIS_To_ADLS",
							"type": "PipelineReference"
						},
						"parameters": {
							"pipelineRunDate": "[parameters('TriggerDailySilverToGold_properties_PL_CoreBank_SSIS_To_ADLS_parameters_pipelineRunDate')]",
							"silverPath": "[parameters('TriggerDailySilverToGold_properties_PL_CoreBank_SSIS_To_ADLS_parameters_silverPath')]",
							"goldPath": "[parameters('TriggerDailySilverToGold_properties_PL_CoreBank_SSIS_To_ADLS_parameters_goldPath')]"
