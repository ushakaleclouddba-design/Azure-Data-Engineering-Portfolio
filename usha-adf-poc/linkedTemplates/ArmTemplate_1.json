					},
					{
						"name": "WaitForFile",
						"type": "Until",
						"dependsOn": [
							{
								"activity": "SetVar_FileArrived_True",
								"dependencyConditions": [
									"Completed"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"expression": {
								"value": "@or(equals(variables('FileArrived'),'true'),greaterOrEquals(variables('RetryCount'),10))",
								"type": "Expression"
							},
							"activities": [
								{
									"name": "Wait_30s",
									"type": "Wait",
									"dependsOn": [],
									"userProperties": [],
									"typeProperties": {
										"waitTimeInSeconds": 30
									}
