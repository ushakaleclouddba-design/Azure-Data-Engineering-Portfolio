          SQLTask:Connection="{BFD14A0F-EC84-49D5-A70A-E56AC0BC6F9E}"
          SQLTask:SqlStatementSource="-- Run OS command via xp_cmdshell&#xA;-- This is a hard blocker in Azure SQL MI&#xA;DECLARE @output TABLE (output NVARCHAR(255));&#xA;&#xA;INSERT INTO @output&#xA;EXEC xp_cmdshell 'dir C:\SSIS_Output\*.csv';&#xA;&#xA;SELECT * FROM @output;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
