          SQLTask:SqlStatementSource="-- Enable xp_cmdshell&#xA;-- DMA flags this as migration blocker in SQL MI&#xA;EXEC sp_configure 'show advanced options', 1;&#xA;RECONFIGURE;&#xA;EXEC sp_configure 'xp_cmdshell', 1;&#xA;RECONFIGURE;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
