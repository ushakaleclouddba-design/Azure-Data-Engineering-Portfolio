    <DTS:Executable
      DTS:refId="Package\SQL_CallCLRProcedure"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{F100F8B9-138E-4FB5-8B8A-1067684AA87D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_CallCLRProcedure"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D7F464C1-39DD-4C2B-BAB2-303AA9502E49}"
          SQLTask:SqlStatementSource="-- Call CLR stored procedure&#xA;-- DMA flags CLR dependencies as migration warning&#xA;-- CLR assemblies require re-signing in Azure SQL MI&#xA;DECLARE @FormattedAmount NVARCHAR(50);&#xA;&#xA;EXEC dbo.usp_CLR_FormatCurrency&#xA;    @Amount = 1234567.89,&#xA;    @FormattedAmount = @FormattedAmount OUTPUT;&#xA;&#xA;SELECT @FormattedAmount AS FormattedCurrencyOutput;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_LogCLRResult"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{29E21DE6-224C-4C37-95F6-8C98A6488D73}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_LogCLRResult"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D7F464C1-39DD-4C2B-BAB2-303AA9502E49}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.ETL_PipelineLog &#xA;    (PackageName, StepName, SourceSystem, StartTime, Status, ExecutedBy)&#xA;VALUES &#xA;    ('PKG_07_CLR', 'CLR Procedure Execution Complete', &#xA;     'BankingDW_DB', GETDATE(), 'Success', SYSTEM_USER);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_VerifyCLROutput"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{26263B67-B910-4F15-B81E-2BE997C8E403}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_VerifyCLROutput"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D7F464C1-39DD-4C2B-BAB2-303AA9502E49}"
          SQLTask:SqlStatementSource="-- Verify CLR procedure ran successfully&#xA;-- Check ETL log for CLR execution record&#xA;SELECT TOP 1&#xA;    PackageName,&#xA;    StepName,&#xA;    Status,&#xA;    StartTime&#xA;FROM dbo.ETL_PipelineLog&#xA;WHERE PackageName = 'CLR_Dependency'&#xA;ORDER BY StartTime DESC;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
