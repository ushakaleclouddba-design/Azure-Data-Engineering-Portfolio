{
	"name": "DFSilverToGold",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_ADLS_Parquet_Silver",
						"type": "DatasetReference"
					},
					"name": "DFSilverToGold"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_ADLS_Parquet_Gold",
						"type": "DatasetReference"
					},
					"name": "SinkGold"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          TransactionID as string,",
				"          AccountID as string,",
				"          TransactionDate as string,",
				"          PostedDate as string,",
				"          TransactionType as string,",
				"          Amount as string,",
				"          RunningBalance as string,",
				"          Description as string,",
				"          ReferenceNumber as string,",
				"          Channel as string,",
				"          Remarks as string,",
				"          CreatedDate as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> DFSilverToGold",
				"DFSilverToGold aggregate(groupBy(TransactionType),",
				"     TotalAmount = sum(toDouble(Amount)),",
				"          TransactionCount = count(TransactionID),",
				"          AvgAmount = avg(toDouble(Amount))) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     partitionFileNames:['gold_transactions.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SinkGold"
			]
		}
	}
}