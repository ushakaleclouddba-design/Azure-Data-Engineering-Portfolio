{
	"name": "PL_LoanProcessing_Branch",
	"properties": {
		"activities": [
			{
				"name": "SetVar_RetryCount",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "RetryCount",
					"value": 0
				}
			},
			{
				"name": "WaitForFile",
				"type": "Until",
				"dependsOn": [
					{
						"activity": "SetVar_RetryCount",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@or(equals(variables('FileArrived'),'true'),greaterOrEquals(variables('RetryCount'),10))",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "Wait_30s",
							"type": "Wait",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"waitTimeInSeconds": 30
							}
						},
						{
							"name": "CheckFileArrived",
							"type": "GetMetadata",
							"dependsOn": [
								{
									"activity": "Wait_30s",
									"dependencyConditions": [
										"Completed"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataset": {
									"referenceName": "DS_Node5_LoanFiles",
									"type": "DatasetReference",
									"parameters": {
										"Filename": "@concat(pipeline().parameters.BranchID,'_loans.csv')"
									}
								},
								"fieldList": [
									"exists"
								],
								"storeSettings": {
									"type": "FileServerReadSettings",
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "DelimitedTextReadSettings"
								}
							}
						},
						{
							"name": "SetVar_FileArrived",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "CheckFileArrived",
									"dependencyConditions": [
										"Completed"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "FileArrived",
								"value": "@string(activity('CheckFileArrived').output.exists)"
							}
						}
					],
					"timeout": "0.00:06:00"
				}
			}
		],
		"parameters": {
			"BranchID": {
				"type": "string"
			},
			"RunDate": {
				"type": "string"
			},
			"LoanType": {
				"type": "string"
			}
		},
		"variables": {
			"RetryCount": {
				"type": "Integer"
			},
			"FileArrived": {
				"type": "String"
			},
			"RejectedIDs": {
				"type": "Array"
			}
		},
		"annotations": []
	}
}