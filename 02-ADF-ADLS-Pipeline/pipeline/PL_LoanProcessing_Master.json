{
	"name": "PL_LoanProcessing_Master",
	"properties": {
		"activities": [
			{
				"name": "AKV_GetSecrets",
				"type": "WebActivity",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "GET",
					"url": "https://usha-kv-poc.vault.azure.net/secrets/sqlPassword/?api-version=7.0",
					"authentication": {
						"type": "MSI",
						"resource": "https://vault.azure.net"
					}
				}
			},
			{
				"name": "CheckBusinessDay",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "AKV_GetSecrets",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@and(and(not(equals(dayOfWeek(utcNow()),0)),not(equals(dayOfWeek(utcNow()),6))),not(contains(variables('HolidayList'),formatDateTime(utcNow(),'yyyy-MM-dd'))))",
						"type": "Expression"
					},
					"ifFalseActivities": [
						{
							"name": "LogNonBusinessDay",
							"type": "SqlServerStoredProcedure",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"storedProcedureName": "[dbo].[usp_LogPipelineRun]",
								"storedProcedureParameters": {
									"ApprovedCount": {
										"value": "0",
										"type": "Int32"
									},
									"BranchID": {
										"value": "Master",
										"type": "String"
									},
									"PipelineRunID": {
										"value": {
											"value": "@pipeline().RunId",
											"type": "Expression"
										},
										"type": "String"
									},
									"RejectedCount": {
										"value": "0",
										"type": "Int32"
									},
									"RunDate": {
										"value": {
											"value": "@formatDateTime(utcNow(),'yyyy-MM-dd')",
											"type": "Expression"
										},
										"type": "DateTime"
									},
									"Status": {
										"value": "skipped",
										"type": "String"
									}
								}
							},
							"linkedServiceName": {
								"referenceName": "LS_AzureSQL_LoanProcessing",
								"type": "LinkedServiceReference"
							}
						}
					]
				}
			},
			{
				"name": "AlertOnFailure",
				"type": "WebActivity",
				"dependsOn": [
					{
						"activity": "CheckBusinessDay",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"headers": {
						"Content-Type": "application/json"
					},
					"url": "https://httpbin.org/post",
					"body": {
						"value": "@concat('{\"pipeline\":\"',pipeline().DataFactory,'\",\"status\":\"FAILED\",\"time\":\"',utcNow(),'\"}')",
						"type": "Expression"
					}
				}
			},
			{
				"name": "ForEach_Branches",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "CheckBusinessDay",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@variables('BranchList')",
						"type": "Expression"
					},
					"isSequential": true,
					"activities": [
						{
							"name": "Execute_BranchPipeline",
							"type": "ExecutePipeline",
							"dependsOn": [],
							"policy": {
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "PL_LoanProcessing_Branch",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"BranchID": "BranchID = @item()",
									"RunDate": "@formatDateTime(utcNow(),'yyyy-MM-dd')",
									"LoanType": "Mortgage"
								}
							}
						}
					]
				}
			}
		],
		"variables": {
			"BranchList": {
				"type": "Array",
				"defaultValue": [
					"SF_Downtown",
					"SanRamon_EastBay",
					"Oakland_Financial"
				]
			},
			"HolidayList": {
				"type": "Array",
				"defaultValue": [
					"2026-01-01",
					"2026-05-25",
					"2026-07-04",
					"2026-09-07",
					"2026-11-26",
					"2026-12-25"
				]
			},
			"PipelineStatus": {
				"type": "String",
				"defaultValue": "RUNNING"
			}
		},
		"annotations": []
	}
}